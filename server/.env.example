# Server environment variables
# Copy to .env and fill in values

# TRON Network: nile | shasta | mainnet
TRON_NETWORK=nile
TRON_FULL_HOST=https://nile.trongrid.io
TRON_PRIVATE_KEY=
PAYMENT_RECIPIENT=

# Bank of AI Facilitator
FACILITATOR_URL=https://facilitator.bankofai.io

# LLM API (OpenAI-compatible)
LLM_API_URL=http://yy.dbh.baidu-int.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4.1

# Server
PORT=3000
CORS_ORIGIN=*

# Set to true to run without real TRON keys (demo mode)
MOCK_MODE=true
